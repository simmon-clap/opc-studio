# 本地数据目录（SQLite + 项目产出物）
OPC_DATA_DIR=./data

# Fernet 密钥，用于加密角色 API Key（生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
OPC_SECRET_KEY=

# 服务绑定
OPC_HOST=127.0.0.1
OPC_PORT=8765

# 公网暴露时建议设置（Cloudflare Access 或反向代理层校验更省心）
# OPC_ACCESS_TOKEN=

# 应用版本见根目录 VERSION（health / 前端缓存与此同步）
