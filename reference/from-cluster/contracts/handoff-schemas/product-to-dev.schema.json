{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "product-to-dev",
  "type": "object",
  "required": ["handoff_id", "project_id", "vertical", "prd_path", "acceptance_path", "status"],
  "properties": {
    "handoff_id": { "type": "string" },
    "project_id": { "type": "string" },
    "vertical": { "enum": ["invoice", "exam", "internal-flow", "opc-community"] },
    "prd_path": { "type": "string" },
    "acceptance_path": { "type": "string" },
    "data_boundary": { "type": "string" },
    "poc_deadline_weeks": { "type": "integer", "minimum": 1, "maximum": 8 },
    "status": { "enum": ["draft", "pending_hitl", "approved", "rejected"] },
    "approved_by": { "type": "string" },
    "approved_at": { "type": "string", "format": "date-time" }
  }
}
