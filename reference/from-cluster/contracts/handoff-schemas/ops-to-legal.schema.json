{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops-to-legal",
  "type": "object",
  "required": ["handoff_id", "period", "reconciliation_path", "variance_cents", "status"],
  "properties": {
    "handoff_id": { "type": "string" },
    "period": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "reconciliation_path": { "type": "string" },
    "variance_cents": { "type": "integer" },
    "subsidy_total_cents": { "type": "integer" },
    "status": { "enum": ["draft", "pending_hitl", "approved", "rejected"] }
  }
}
